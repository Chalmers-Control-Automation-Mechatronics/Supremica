<?xml version="1.0" encoding="ISO-8859-1"?>
<ProductDES xmlns="http://waters.sourceforge.net/xsd/des" xmlns:B="http://waters.sourceforge.net/xsd/base" Name="divzer2">
<B:Comment>A test to check how division by zero is handled.
The action x=2/x does not resuls in a diviision by zero error because the compiler cannot rule out the divisor x to be zero using the guard x!=0.</B:Comment>
<EventList>
<Event Kind="CONTROLLABLE" Name="e"/>
</EventList>
<AutomataList>
<Automaton Kind="PLANT" Name="x">
<EventRefList>
<EventRef Name="e"/>
</EventRefList>
<StateList>
<State Name="0"/>
<State Initial="true" Name="1"/>
<State Name="2"/>
</StateList>
<TransitionList>
<Transition Source="1" Event="e" Target="2"/>
<Transition Source="2" Event="e" Target="1"/>
</TransitionList>
</Automaton>
<Automaton Kind="PLANT" Name="A">
<EventRefList>
<EventRef Name="e"/>
</EventRefList>
<StateList>
<State Initial="true" Name="S0"/>
<State Name="S1"/>
</StateList>
<TransitionList>
<Transition Source="S0" Event="e" Target="S1"/>
</TransitionList>
</Automaton>
</AutomataList>
</ProductDES>
