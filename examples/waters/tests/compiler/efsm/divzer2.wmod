<?xml version="1.0" encoding="ISO-8859-1"?>
<Module xmlns="http://waters.sourceforge.net/xsd/module" xmlns:B="http://waters.sourceforge.net/xsd/base" Name="divzer2">
<B:Comment>A test to check how division by zero is handled.
The action x=2/x does not resuls in a diviision by zero error because the compiler cannot rule out the divisor x to be zero using the guard x!=0.</B:Comment>
<EventDeclList>
<EventDecl Kind="CONTROLLABLE" Name="e"/>
</EventDeclList>
<ComponentList>
<VariableComponent Name="x">
<VariableRange><BinaryExpression Operator="..">
<IntConstant Value="0"/>
<IntConstant Value="2"/>
</BinaryExpression>
</VariableRange>
<VariableInitial><BinaryExpression Operator="==">
<SimpleIdentifier Name="x"/>
<IntConstant Value="1"/>
</BinaryExpression>
</VariableInitial>
</VariableComponent>
<SimpleComponent Kind="PLANT" Name="A">
<Graph>
<NodeList>
<SimpleNode Initial="true" Name="S0">
<PointGeometry>
<Point X="96" Y="96"/>
</PointGeometry>
<LabelGeometry Anchor="NW">
<Point X="11" Y="-5"/>
</LabelGeometry>
</SimpleNode>
<SimpleNode Name="S1">
<PointGeometry>
<Point X="96" Y="176"/>
</PointGeometry>
<LabelGeometry Anchor="NW">
<Point X="10" Y="-5"/>
</LabelGeometry>
</SimpleNode>
</NodeList>
<EdgeList>
<Edge Source="S0" Target="S1">
<LabelBlock>
<SimpleIdentifier Name="e"/>
<LabelGeometry Anchor="NW">
<Point X="10" Y="-22"/>
</LabelGeometry>
</LabelBlock>
<EndPointGeometry>
<Point X="96" Y="176"/>
</EndPointGeometry>
<GuardActionBlock>
<Guards>
<BinaryExpression Operator="!=">
<SimpleIdentifier Name="x"/>
<IntConstant Value="0"/>
</BinaryExpression>
</Guards>
<Actions>
<BinaryExpression Operator="=">
<SimpleIdentifier Name="x"/>
<BinaryExpression Operator="/">
<IntConstant Value="2"/>
<SimpleIdentifier Name="x"/>
</BinaryExpression>
</BinaryExpression>
</Actions>
<LabelGeometry Anchor="NW">
<Point X="12" Y="-4"/>
</LabelGeometry>
</GuardActionBlock>
</Edge>
</EdgeList>
</Graph>
</SimpleComponent>
</ComponentList>
</Module>
